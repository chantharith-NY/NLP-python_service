# =============================================================================
# AWS / S3 Configuration
# =============================================================================
# Required for downloading LoRA adapters from S3

AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-southeast-1
S3_BUCKET=your_s3_bucket_name
S3_ADAPTER_PREFIX=models/adapters


# =============================================================================
# HuggingFace Configuration
# =============================================================================
# Required for downloading models from HuggingFace Hub

HUGGINGFACE_HUB_TOKEN=your_huggingface_token_here


# =============================================================================
# Base Model Configuration
# =============================================================================
# Configure the base Qwen model and quantization

BASE_MODEL=Qwen/Qwen2.5-1.5B-Instruct
USE_4BIT_QUANTIZATION=true
MAX_ADAPTERS_CACHED=5


# =============================================================================
# Adapter/Cache Configuration
# =============================================================================
# Control where adapters are stored and loaded from

ADAPTER_CACHE_DIR=./models/adapters
BASE_MODEL_CACHE_DIR=./models/base
ADAPTER_SOURCE=local

# Per-model configuration (optional - can be overridden per model)
SUMMARIZER_REPO=chantharith/qwen-summarizer
SUMMARIZER_SOURCE=hf
SPELLCHECKER_REPO=chantharith/qwen-spellchecker
SPELLCHECKER_SOURCE=hf


# =============================================================================
# Database/Reload Configuration
# =============================================================================
# Enable dynamic model loading from Laravel database

LOAD_MODELS_FROM_DB=false
LARAVEL_API_URL=http://127.0.0.1:8000/api


# =============================================================================
# API Configuration
# =============================================================================
# Configure FastAPI service

API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=1


# =============================================================================
# Logging Configuration
# =============================================================================
# Set logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL

LOG_LEVEL=INFO


# =============================================================================
# Generation Configuration (Defaults)
# =============================================================================
# Default parameters for text generation (can be overridden per request)

DEFAULT_MAX_TOKENS=256
DEFAULT_TEMPERATURE=0.7
DEFAULT_TOP_P=0.9
DEFAULT_MAX_TIME=20.0
